# Playwright E2E Test Environment Variables
# Copy this file to .env.test and fill in values

# Clerk Test Credentials
# Create a test user in your Clerk dashboard
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=your-secure-test-password

# Clerk Test Organization (optional, for org-scoped tests)
CLERK_TEST_ORG_ID=org_xxxxx

# Base URL for tests
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Optional: Clerk API keys for test setup/teardown
# CLERK_SECRET_KEY=sk_test_xxxxx
