{
  "name": "revenue-recognition-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:no-mcp": "turbo dev --filter='!@glapi/mcp-server'",
    "dev:mcp": "cd packages/mcp-server && nvm use 20 && pnpm dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "db:migrate": "turbo run migrate --filter=database",
    "db:generate": "turbo run generate --filter=database",
    "db:studio": "turbo run studio --filter=database",
    "dev:api": "pnpm --filter @glapi/api dev",
    "precommit": "./scripts/precommit.sh",
    "lint:fix": "turbo lint:fix",
    "api:mock": "prism mock docs/api-specs/*.openapi.yaml",
    "api:validate": "prism validate docs/api-specs/*.openapi.yaml",
    "api:generate-sdk": "pnpm --filter @glapi/sdk generate",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:debug": "playwright test --debug",
    "test:playwright:install": "playwright install"
  },
  "workspaces": [
    "packages/*",
    "packages/lambdas/*",
    "apps/*"
  ],
  "devDependencies": {
    "@pact-foundation/pact": "^15.0.1",
    "@playwright/test": "^1.40.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "js-yaml": "^4.1.0",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.2.4",
    "turbo": "^1.13.3",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
