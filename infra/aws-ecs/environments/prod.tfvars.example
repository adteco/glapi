environment       = "prod"
web_domain_name   = "web.glapi.net"
api_domain_name   = "api.glapi.net"
vpc_id            = "vpc-xxxxxxxx"
public_subnet_ids = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
certificate_arn   = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/PROD_CERT_ID"
web_secret_arn    = "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:glapi/prod/web"
api_secret_arn    = "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:glapi/prod/api"
web_desired_count = 2
api_desired_count = 2
