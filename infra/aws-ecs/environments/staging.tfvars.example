environment       = "staging"
aws_region        = "us-east-1"
web_domain_name   = "glapi-staging.adteco.com"
api_domain_name   = "glapi-staging-api.adteco.com"
route53_zone_name = "adteco.com"

vpc_id   = "vpc-xxxxxxxx"
vpc_cidr = "10.0.0.0/16"
public_subnet_ids = [
  "subnet-xxxxxxxx",
  "subnet-yyyyyyyy",
]

certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/STAGING_CERT_ID"
web_secret_name = "glapi/staging/web"
api_secret_name = "glapi/staging/api"

web_desired_count = 1
api_desired_count = 1
