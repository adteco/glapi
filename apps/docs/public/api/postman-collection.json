          "name": "Test Authentication",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "{{api_key}}",
                "value": "{{api_key_value}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/customers",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "customers"
              ]
            },
            "description": "Test that your API key is working by fetching customers"
          }
        }
      ]
