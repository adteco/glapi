{
  "info": {
    "name": "GLAPI - General Ledger API",
    "description": "The GLAPI provides a comprehensive REST API for managing accounting dimensions and financial data.\n\n## Authentication\n\nAll API requests must be authenticated using an API key in the `X-API-Key` header:\n\n```\nX-API-Key: glapi_test_sk_1234567890abcdef\n```\n\n## Base URL\n\n- Development: `http://localhost:3001/api/v1`\n- Production: `https://api.glapi.net/api/v1`\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "{{api_key}}",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{api_key_value}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001/api/v1",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "X-API-Key",
      "type": "string"
    },
    {
      "key": "api_key_value",
      "value": "glapi_test_sk_1234567890abcdef",
      "type": "string"
    }
  ],
