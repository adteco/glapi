# Database
DATABASE_URL=postgresql://user:password@localhost:5432/glapi

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Outbox Processor Configuration
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
OUTBOX_LOCK_DURATION_MS=30000
OUTBOX_MAX_RETRIES=5
OUTBOX_INITIAL_RETRY_DELAY_MS=1000
OUTBOX_BACKOFF_MULTIPLIER=2
OUTBOX_MAX_RETRY_DELAY_MS=300000

# HTTP Server (metrics/health)
METRICS_PORT=9090
METRICS_HOST=0.0.0.0
