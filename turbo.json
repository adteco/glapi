{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build", "generate:ai-tools"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "generate": {
      "cache": false
    },
    "generate:openapi": {
      "inputs": [
        "src/router.ts",
        "src/routers/**/*.ts",
        "src/openapi-generator.ts",
        "src/ai-meta.ts",
        "scripts/generate-openapi.ts"
      ],
      "outputs": ["../../apps/docs/public/api/openapi.json"]
    },
    "generate:ai-tools": {
      "inputs": [
        "src/router.ts",
        "src/routers/**/*.ts",
        "src/openapi-generator.ts",
        "src/ai-meta.ts",
        "scripts/generate-ai-tools.ts"
      ],
      "outputs": ["../../apps/web/src/lib/ai/generated/**"]
    },
    "migrate": {
      "cache": false
    },
    "studio": {
      "cache": false
    }
  }
}