{
  "name": "@glapi/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./index.ts",
  "typesVersions": {
    "*": {
      ".": ["./src/index.ts"],
      "schema": ["./src/db/schema/index.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./schema": {
      "types": "./schema.ts",
      "import": "./dist/db/schema/index.js",
      "require": "./dist/db/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test:connection": "tsx src/scripts/test-connection.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "seed:test-org": "tsx src/seed-test-org.ts",
    "run:entities-migration": "tsx src/scripts/run-entities-migration.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/dotenv": "^8.2.3",
    "@types/pg": "^8.15.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.2",
    "pg": "^8.15.6",
    "postgres": "^3.4.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.49"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/uuid": "^9.0.7",
    "drizzle-kit": "^0.31.4",
    "drizzle-zod": "^0.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  }
}