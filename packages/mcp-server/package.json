{
  "name": "@glapi/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for GLAPI business operations",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node -e \"if (process.version.match(/^v(\\d+)/)[1] < 20) { console.log('MCP Server requires Node.js v20+. Skipping...'); process.exit(0); } else { require('child_process').execSync('wrangler dev', {stdio: 'inherit'}); }\"",
    "dev:force": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@glapi/database": "workspace:*",
    "@glapi/business": "workspace:*",
    "@glapi/trpc": "workspace:*",
    "@trpc/client": "^11.4.3",
    "@clerk/backend": "^1.15.6",
    "zod": "^3.22.4",
    "superjson": "^2.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/node": "^20.14.8",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0",
    "wrangler": "^4.24.3"
  },
  "keywords": [
    "mcp",
    "ai",
    "business-automation",
    "cloudflare-workers"
  ],
  "author": "GLAPI Team",
  "license": "MIT"
}