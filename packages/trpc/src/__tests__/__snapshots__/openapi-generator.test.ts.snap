exports[`emitAIExtensions > snapshot tests > should match snapshot for full metadata 1`] = `
{
  "x-ai-async": {
    "enabled": true,
    "polling": {
      "maxMs": 10000,
      "minMs": 1000,
    },
    "statusEndpoint": "/api/test/{id}/status",
    "terminalStates": [
      "completed",
      "failed",
      "cancelled",
    ],
  },
  "x-ai-cache": {
    "enabled": true,
    "invalidateOn": [
      "test.updated",
      "test.deleted",
    ],
    "ttlSeconds": 120,
    "varyBy": [
      "id",
      "status",
    ],
  },
  "x-ai-errors": [
    {
      "code": "TEST_NOT_FOUND",
      "retryable": false,
      "userSafeMessage": "The requested test resource was not found.",
    },
    {
      "code": "TEST_CONFLICT",
      "retryable": true,
      "userSafeMessage": "A conflict occurred. Please try again.",
    },
  ],
  "x-ai-financial-limits": {
    "accountant": 50000,
    "admin": 100000,
    "manager": 10000,
    "staff": 1000,
  },
  "x-ai-idempotency": {
    "keySource": "header",
    "ttlSeconds": 3600,
  },
  "x-ai-output": {
    "includeFields": [
      "id",
      "name",
      "status",
    ],
    "maxItems": 50,
    "maxTokens": 1000,
    "redactFields": [
      "ssn",
      "creditCard",
    ],
  },
  "x-ai-permissions": {
    "minimumRole": "manager",
    "required": [
      "write:test",
      "delete:test",
    ],
  },
  "x-ai-policy": {
    "allowTiers": [
      "enterprise",
      "pro",
    ],
    "maxAffectedRecords": 100,
    "requireMfaForRisk": [
      "HIGH",
      "CRITICAL",
    ],
    "rowScope": "organization.id == user.orgId",
  },
  "x-ai-rate-limit": {
    "burstLimit": 5,
    "requestsPerMinute": 30,
    "scope": "organization",
  },
  "x-ai-risk": {
    "confirmationMessage": "Are you sure you want to proceed?",
    "level": "HIGH",
    "requiresConfirmation": true,
    "supportsDryRun": true,
  },
  "x-ai-timeouts": {
    "hardMs": 15000,
    "retryable": false,
    "softMs": 5000,
  },
  "x-ai-tool": {
    "deprecated": true,
    "description": "A fully configured test tool",
    "enabled": true,
    "exampleUtterances": [
      "test this tool",
      "use the test tool",
    ],
    "name": "full_test_tool",
    "replacement": "new_test_tool",
    "scopes": [
      "sales",
      "finance",
    ],
    "stability": "beta",
    "version": 2,
  },
}
`;

