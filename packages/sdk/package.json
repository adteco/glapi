{
  "name": "@glapi/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for GLAPI - General Ledger and Accounting API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi --input ../../apps/docs/public/api/openapi.json --output ./src/generated --client axios --useOptions --useUnionTypes",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "openapi-typescript-codegen": "^0.29.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "keywords": [
    "glapi",
    "accounting",
    "api",
    "sdk",
    "typescript",
    "general-ledger",
    "revenue-recognition"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glapi/glapi.git",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
