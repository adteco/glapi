# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/glapi?sslmode=require
DATABASE_ADMIN_URL=postgresql://admin:password@localhost:5432/glapi?sslmode=require

# Magic Inbox Internal API Key
# Used by magic-inbox-processor Lambda to authenticate with GLAPI internal endpoints
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=your-secure-random-token-here
