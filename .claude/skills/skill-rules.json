{
    "version": "1.0",
    "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
            
        },
        "glapi-backend-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "GLAPI backend development with Next.js/TRPC/Drizzle/PostgreSQL - TRPC for type-safe APIs, OpenAPI for REST exposure",
            "promptTriggers": {
                "keywords": [
                    "backend",
                    "backend development",
                    "TRPC",
                    "trpc",
                    "procedure",
                    "router",
                    "API route",
                    "api route",
                    "route handler",
                    "REST API",
                    "service",
                    "API",
                    "endpoint",
                    "Drizzle",
                    "drizzle",
                    "database",
                    "query",
                    "PostgreSQL",
                    "postgres",
                    "Clerk",
                    "clerk",
                    "authentication",
                    "auth",
                    "validation",
                    "Zod",
                    "server action",
                    "OpenAPI"
                ],
                "intentPatterns": [
                    "(create|add|implement|build).*?(TRPC|trpc|procedure|router|API route|route handler|endpoint|API|service|REST)",
                    "(fix|handle|debug).*?(error|exception|backend)",
                    "(add|implement).*?(validation|auth.*?authentication)",
                    "(organize|structure|refactor).*?(backend|service|API)",
                    "(how to|best practice).*?(backend|TRPC|API route|service|drizzle|clerk|REST)",
                    "query.*?(drizzle|database|postgres)",
                    "server action",
                    "(convert|expose|transform).*?(TRPC.*REST|REST.*TRPC)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "apps/api/src/**/*.ts",
                    "apps/api/src/**/*.tsx",
                    "apps/web/src/app/api/**/*.ts",
                    "apps/web/src/app/api/**/*.tsx",
                    "packages/api-service/**/*.ts",
                    "packages/business/**/*.ts",
                    "packages/database/**/*.ts",
                    "packages/trpc/**/*.ts"
                ],
                "pathExclusions": [
                    "**/*.test.ts",
                    "**/*.spec.ts"
                ],
                "contentPatterns": [
                    "from '@glapi/database'",
                    "from \"@glapi/database\"",
                    "from '@glapi/api-service'",
                    "from \"@glapi/api-service\"",
                    "from '@glapi/business'",
                    "from \"@glapi/business\"",
                    "createTRPCRouter",
                    "publicProcedure",
                    "protectedProcedure",
                    "\\.query\\(",
                    "\\.mutation\\(",
                    "drizzle(",
                    "db.select",
                    "db.insert",
                    "db.update",
                    "db.delete",
                    "auth\\(\\)",
                    "currentUser",
                    "@clerk/nextjs",
                    "NextRequest",
                    "NextResponse"
                ]
            }
        },
        "glapi-frontend-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "GLAPI frontend development with Next.js App Router/shadcn-ui/Radix UI/Tailwind/Clerk auth patterns",
            "promptTriggers": {
                "keywords": [
                    "frontend",
                    "component",
                    "react component",
                    "UI",
                    "interface",
                    "page",
                    "modal",
                    "dialog",
                    "form",
                    "ShadCN",
                    "shadcn",
                    "Radix UI",
                    "Radix",
                    "Tailwind",
                    "tailwind",
                    "styling",
                    "React",
                    "cn utility",
                    "cva",
                    "dark mode",
                    "next-themes",
                    "TanStack Query",
                    "useQuery",
                    "useMutation"
                ],
                "intentPatterns": [
                    "(create|add|make|build|update|modify|edit).*?(component|UI|page|modal|dialog|form)",
                    "(how to|best practice).*?(component|react|ShadCN|Radix|Tailwind|styling)",
                    "(style|design|layout).*?(component|UI)",
                    "(use|integrate).*?(ShadCN|Radix|Tailwind|dark mode|TanStack Query)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "apps/web/src/**/*.tsx",
                    "apps/web/src/**/*.ts",
                    "apps/api/src/**/*.tsx",
                    "apps/api/src/**/*.ts"
                ],
                "pathExclusions": [
                    "**/*.test.tsx",
                    "**/*.test.ts",
                    "**/*.spec.tsx",
                    "**/*.spec.ts",
                    "**/next.config.js",
                    "**/next.config.mjs",
                    "**/tailwind.config.js",
                    "**/tailwind.config.ts",
                    "**/tsconfig.json"
                ],
                "contentPatterns": [
                    "from '@/components/ui",
                    "from \"@/components/ui",
                    "import.*{.*cn.*}.*from",
                    "@radix-ui/react",
                    "className=",
                    "cva\\(",
                    "buttonVariants",
                    "useTheme.*from.*next-themes",
                    "useQuery.*from.*@tanstack",
                    "useMutation.*from.*@tanstack"
                ]
            }
        },
        "glapi-rls-guide": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Row Level Security (RLS) implementation guide for GLAPI multi-tenant database isolation. Covers PostgreSQL RLS policies, session variables, contextual database connections, tRPC middleware, and common troubleshooting. Use when working with RLS, multi-tenancy, organization isolation, database security, or debugging RLS policy violations.",
            "promptTriggers": {
                "keywords": [
                    "RLS",
                    "row level security",
                    "row-level security",
                    "multi-tenant",
                    "multi-tenancy",
                    "organization isolation",
                    "tenant isolation",
                    "session variable",
                    "current_setting",
                    "app.current_organization_id",
                    "RLS policy",
                    "policy violation",
                    "contextual db",
                    "contextual database",
                    "createContextualDb",
                    "withOrganizationContext"
                ],
                "intentPatterns": [
                    "(create|add|implement|fix|debug).*?(RLS|row level security|policy)",
                    "(how does|explain|understand).*?(RLS|multi-tenant|isolation)",
                    "violates.*?row.*?level.*?security",
                    "organization.*?(id|isolation|context)",
                    "(set|get).*?session.*?variable"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "packages/database/src/context.ts",
                    "packages/database/drizzle/*rls*.sql",
                    "packages/trpc/src/trpc.ts"
                ],
                "contentPatterns": [
                    "ENABLE ROW LEVEL SECURITY",
                    "CREATE POLICY",
                    "current_setting\\(",
                    "set_config\\(",
                    "createContextualDb",
                    "withOrganizationContext",
                    "app\\.current_organization_id"
                ]
            }
        },
        "database-migrations": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Database schema changes, migrations, and table modifications. Use psql directly (NOT Drizzle Kit) with DATABASE_ADMIN_URL.",
            "promptTriggers": {
                "keywords": [
                    "migration",
                    "schema change",
                    "add column",
                    "create table",
                    "alter table",
                    "database change",
                    "new table",
                    "add field",
                    "drizzle migration",
                    "db:migrate",
                    "psql"
                ],
                "intentPatterns": [
                    "(create|add|modify|change|update).*?(table|column|field|schema|migration)",
                    "(run|execute|apply).*?migration",
                    "(how to|best practice).*?(migration|schema change|add column)",
                    "database.*?(change|update|modify)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "packages/database/drizzle/*.sql",
                    "packages/database/src/db/schema/*.ts"
                ],
                "contentPatterns": [
                    "CREATE TABLE",
                    "ALTER TABLE",
                    "ADD COLUMN",
                    "CREATE INDEX",
                    "CREATE POLICY",
                    "pgTable\\(",
                    "\\$inferSelect",
                    "\\$inferInsert"
                ]
            }
        },
        "error-tracking": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Sentry error tracking and performance monitoring patterns",
            "promptTriggers": {
                "keywords": [
                    "error handling",
                    "exception",
                    "sentry",
                    "error tracking",
                    "captureException",
                    "monitoring",
                    "performance tracking"
                ],
                "intentPatterns": [
                    "(add|create|implement|setup).*?(error handling|sentry|error tracking)",
                    "(fix|handle|catch).*?(error|exception)",
                    "(how to|best practice).*?(error|sentry|monitoring)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "apps/*/instrumentation.ts",
                    "apps/*/sentry*.ts",
                    "apps/api/src/services/**/*.ts",
                    "apps/api/src/server/routers/**/*.ts",
                    "packages/*/src/services/**/*.ts"
                ],
                "contentPatterns": [
                    "@sentry",
                    "Sentry\\.",
                    "captureException",
                    "captureMessage"
                ]
            }
        },
        "pre-deploy-checklist": {
            "type": "workflow",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Pre-deployment quality checklist for commits and PRs. Validates TypeScript, linting, build, OpenAPI specs, tests, changelog, and security.",
            "promptTriggers": {
                "keywords": [
                    "ship",
                    "deploy",
                    "pre-deploy",
                    "checklist",
                    "commit",
                    "PR",
                    "pull request",
                    "ready to ship",
                    "ready to deploy",
                    "quality check",
                    "pre-commit",
                    "OpenAPI",
                    "API spec",
                    "changelog"
                ],
                "intentPatterns": [
                    "(ship|deploy|commit|push|PR|pull request).*?(code|changes|feature)",
                    "(ready|prepare).*?(deploy|ship|commit|PR)",
                    "(run|execute).*?(checklist|checks|validation)",
                    "(check|validate|verify).*?(before|pre).*?(commit|deploy|ship)",
                    "(update|regenerate).*?(OpenAPI|API spec|docs)",
                    "(is|are).*?(OpenAPI|spec|docs).*?(up.?to.?date|current|updated)"
                ]
            },
            "slashCommands": [
                "/ship",
                "/pre-deploy",
                "/checklist",
                "/quality-check"
            ]
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "customization": {
            "pathPatterns": "Adjust to match your project structure (blog-api, auth-service, etc.)",
            "keywords": "Add domain-specific terms relevant to your project",
            "intentPatterns": "Use regex for flexible user intent matching"
        }
    }
}
